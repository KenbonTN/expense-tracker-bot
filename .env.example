# Copy this file to .env and fill in your values
# Then run:  pip install -r requirements.txt && python bot.py

TELEGRAM_TOKEN=your_telegram_bot_token_here
SPREADSHEET_ID=your_google_spreadsheet_id_here
MY_CHAT_ID=your_telegram_user_id_here

# For cloud deployments (Railway, etc.): paste the full contents of your
# Google service account JSON file as the value of this variable.
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# For local development only: path to your credentials JSON file.
# If GOOGLE_CREDENTIALS_JSON is set, this is ignored.
GOOGLE_CREDENTIALS_FILE=your_credentials_file.json
